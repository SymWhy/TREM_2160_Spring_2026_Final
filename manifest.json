{
  "manifest_version": 3,
  "name": "Fact Check Text",
  "version": "1.0",
  "description": "Highlight and fact check claims on websites.",

  "icons": {
    "16": "icon/icon-16.png",
    "48": "icon/icon-48.png",
    "128": "icon/icon-128.png"
  },

  "permissions": ["contextMenus", "menus", "tabs"],

  "browser_specific_settings": {
    "gecko": {
      "id": "factchecktext@mozilla.org",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "background": {
    "scripts": ["src/background.js"]
  },

  "web_accessible_resources": [
    {
      "resources": ["res/logos/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}